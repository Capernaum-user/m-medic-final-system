import os
import chromadb
from langchain_community.vectorstores import Chroma
from langchain_huggingface import HuggingFaceEmbeddings

# ─── 경로 설정 (라즈베리파이 USB 마운트 경로 사용) ──────────────────────────
CHROMA_PATH = "/home/jetson/remote_vector_db"
COLLECTION_NAME = "medical_knowledge"

class MedicalKnowledgeEngine:
    def __init__(self):
        print(f"[*] 지식 엔진 초기화 중 (경로: {CHROMA_PATH})...")
        # 1. 임베딩 모델 로드 (HuggingFace 로컬 모델 사용)
        self.embeddings = HuggingFaceEmbeddings(
            model_name="jhgan/ko-sroberta-multitask",
            cache_folder="/home/jetson/.cache/huggingface/embeddings"
        )
        self.db = None
        self.load_db()

    def load_db(self):
        """기존 구축된 ChromaDB 컬렉션을 로드합니다."""
        try:
            # LangChain Chroma 클라이언트를 사용하여 기존 디렉토리 로드
            self.db = Chroma(
                persist_directory=CHROMA_PATH,
                embedding_function=self.embeddings,
                collection_name=COLLECTION_NAME
            )
            print(f"[*] Vector DB 로드 성공 (Collection: {COLLECTION_NAME})")
        except Exception as e:
            print(f"[!] Vector DB 로드 실패: {e}")

    def search_relevant_docs(self, query, k=2):
        """질문과 가장 유사한 지침 내용을 찾아옵니다."""
        if not self.db:
            print("[!] DB가 로드되지 않아 검색을 수행할 수 없습니다.")
            return ""

        try:
            print(f"[*] 지식 베이스 검색 중: '{query}'")
            results = self.db.similarity_search(query, k=k)
            context = "\n\n".join([doc.page_content for doc in results])
            return context
        except Exception as e:
            print(f"[!] 검색 중 에러 발생: {e}")
            return ""

if __name__ == "__main__":
    # 독립 테스트용
    engine = MedicalKnowledgeEngine()
    query = "화상 처치 방법 알려줘"
    relevant = engine.search_relevant_docs(query)
    print(f"\n[질문: {query}]")
    print("-" * 50)
    print(relevant)
    print("-" * 50)
